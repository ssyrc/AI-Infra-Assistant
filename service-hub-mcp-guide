3. service hub mcp 활용 방법
# 1. MCP 클라이언트 설치
npm install @modelcontextprotocol/sdk

import { Client } from '@modelcontextprotocol/sdk/client/index.js';
import { StreamableHTTPClientTransport } from '@modelcontextprotocol/sdk/client/streamableHttp.js';

const client = new Client({
  name: 'my-mcp-client',
  version: '1.0.0',
});

const transport = new StreamableHTTPClientTransport(
  new URL('http://innodev--etl-prod.cdep.samsungds.net/mcp')
);

await client.connect(transport);

const result = await client.callTool({
  name: 'rag_keyword_search',
  arguments: { query: '서비스허브 오류', num_result_doc: 3 }
});

console.log(result);

# 2. MCP SDK 설치
pip install mcp

import asyncio
from mcp import ClientSession
from mcp.client.streamable_http import streamablehttp_client

async def main():
    async with streamablehttp_client("http://innodev--etl-prod.cdep.samsungds.net/mcp") as (read, write, _):
        async with ClientSession(read, write) as session:
            await session.initialize()

            # RAG 키워드 검색
            result = await session.call_tool(
                "rag_keyword_search",
                {"query": "서비스허브 오류", "num_result_doc": 3}
            )
            print(result)

asyncio.run(main())


# 3. 사용 가능한 mcp tool

툴 이름	설명	사용 예제
rag_keyword_search	RAG 엔진으로 키워드 검색	"서비스허브 오류" 검색
rag_filtered_search	메타데이터 필터로 정교한 검색	"MOS 시스템 + 권한 오류"
voc_list_query	DB 에서 VOC 목록 조회	최근 100 건 조회
voc_statistics	VOC 통계	시스템별 건수
get_voc_data_by_id	VOC ID 로 상세 조회	특정 VOC 상세
get_metadata_hierarchy	시스템 메타데이터 조회	전체 시스템 목록
help	툴 도움말	사용법 확인


