1. rag_keyword_search
# parameters
파라미터	타입	필수	설명
query	string	✅	검색 질의어
index_name	string	❌	인덱스 이름 (기본값: default)
search_fn	string	❌	검색 함수 이름
num_result_doc	number	❌	결과 문서 수 (기본값: 10)

# 응답 예제
{
  "success": true,
  "data": {
    "total": 5,
    "results": [
      {
        "title": "서비스허브 오류 관련 문서",
        "content": "서비스허브 접속 오류 해결 방법...",
        "score": 0.95
      }
    ]
  }
}

# 사용 예제
## Next.js
const result = await client.callTool({
  name: 'rag_keyword_search',
  arguments: {
    query: '서비스허브 오류',
    num_result_doc: 5
  }
});

## Python
import asyncio
from mcp import ClientSession
from mcp.client.streamable_http import streamablehttp_client

async def main():
    async with streamablehttp_client("http://innodev--etl-prod.cdep.samsungds.net/mcp") as (read, write, _):
        async with ClientSession(read, write) as session:
        await session.connect("http://innodev--etl-prod.cdep.samsungds.net/mcp")
        result = await session.call_tool(
            "rag_keyword_search",
            {"query": "서비스허브 오류", "num_result_doc": 5}
        )
        print(result)

asyncio.run(main())

