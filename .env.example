# 부트스트랩 값만 담는다. vLLM 주소·리랭커·검색 파라미터 등 운영 중 바뀌는 값은
# 관리자 콘솔 '설정' 탭에서 관리한다(platform_config DB).
#
# DB/Redis 접속 정보는 여기 값으로부터 db-init이 자동으로 DSN을 만들어 주입하므로,
# 비밀번호를 바꾸면 각 MCP의 DSN도 자동으로 갱신된다(SQL에 하드코딩하지 않음).
#
# 아래 모든 CHANGE_ME는 배포 전 반드시 실제 값으로 교체할 것.
# 생성 예: openssl rand -base64 32  /  openssl rand -hex 32 (ENCRYPTION_KEY)

# --- PostgreSQL ---
POSTGRES_USER=agent
POSTGRES_PASSWORD=CHANGE_ME_pg_password

# --- 관리자 콘솔 인증 (reverse proxy로 접근망 제한 필수) ---
ADMIN_USER=CHANGE_ME_admin_id
ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- Redis (임베딩 캐시 + Langfuse 큐) ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- agent-server -> Langfuse 트레이싱 (키를 비우면 트레이싱 비활성화) ---
# 아래 키는 langfuse-web의 LANGFUSE_INIT_*로 자동 생성되는 값과 동일해야 한다.
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME

# --- Langfuse v3 인프라 ---
LANGFUSE_NEXTAUTH_URL=http://localhost:3001
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret
LANGFUSE_SALT=CHANGE_ME_salt
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_from_openssl_rand_hex_32
CLICKHOUSE_PASSWORD=CHANGE_ME_clickhouse_password
MINIO_PASSWORD=CHANGE_ME_minio_password
