# 이 파일은 "부트스트랩" 값만 담는다 - 모든 서비스가 시작할 때 config DB(platform_config)에
# 접속하기 위한 최소 정보. vLLM 주소, 각 MCP DB DSN, MCP 엔드포인트, System 스케줄러 주소 등
# "운영 중 바뀔 수 있는 값"은 여기 없다 -> 관리자 콘솔 '설정' 탭에서 관리한다
# (최초 기동 후 반드시 설정 탭에서 CHANGE-ME 값들을 실제 vLLM 서버 주소로 바꿔야 한다).

# --- PostgreSQL (bare-metal 단일 인스턴스, DB만 서비스별로 분리) ---
POSTGRES_PASSWORD=changeme
CONFIG_DB_DSN=postgresql://agent:changeme@postgres:5432/platform_config

# --- 관리자 콘솔 인증 (HTTP Basic, 리버스 프록시로 접근망 제한 권장) ---
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# --- Langfuse (비밀값이라 config DB가 아니라 여기서 관리) ---
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_NEXTAUTH_SECRET=changeme
LANGFUSE_SALT=changeme
